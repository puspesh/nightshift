{
  "name": "nightshift",
  "version": "0.2.0",
  "description": "Coordinating AI agents for your development pipeline. Set up 5 agents (producer, planner, reviewer, coder, tester) in any repository.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r lib/miniverse/core dist/lib/miniverse/",
    "pretest": "tsc",
    "test": "node --test 'dist/tests/*.test.js'",
    "typecheck": "tsc --noEmit",
    "measure": "bash scripts/measure-build.sh"
  },
  "bin": {
    "nightshift": "./dist/bin/nightshift.js"
  },
  "files": [
    "bin/ns-status.sh",
    "dist/",
    "presets/",
    "defaults/",
    "examples/",
    "docs/",
    "worlds/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "pipeline",
    "claude",
    "development",
    "automation",
    "code-review",
    "planning"
  ],
  "author": "Nightshift Agents <https://github.com/nightshift-agents>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nightshift-agents/nightshift.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "prompts": "^2.4.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.5.10",
    "typescript": "^5.9.3"
  }
}
